---
import SEO from '@components/SEO.astro';
import type { Props as SEOProps } from '@components/SEO.astro';
import '@styles/global.css';

export interface Props extends SEOProps {
  bodyClass?: string;
}

const { bodyClass, ...seoProps } = Astro.props;
---

<!doctype html>
<html lang="he" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#fdfbf7" media="(prefers-color-scheme: light)" />
    <meta name="theme-color" content="#1a0c09" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />

    <SEO {...seoProps} />

    <!-- Preconnect to font CDN if using web fonts -->
    <slot name="head" />
  </head>

  <body class={`pb-16 lg:pb-0${bodyClass ? ` ${bodyClass}` : ''}`}>
    <!-- Skip navigation for screen readers and keyboard users -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:start-4 focus:z-50 focus:rounded-lg focus:bg-teal-800 focus:px-4 focus:py-2 focus:text-white focus:outline-none"
    >
      דלג לתוכן הראשי
    </a>

    <slot name="header" />

    <main id="main-content" tabindex="-1">
      <slot />
    </main>

    <slot name="footer" />

    <!-- Fixed overlays (sticky bars, modals) — keeps them inside <body> -->
    <slot name="overlay" />

    <!-- Slot for page-level scripts -->
    <slot name="scripts" />

    <script>
      // Scroll-reveal: fade-in-up for all sections except hero
      const observer = new IntersectionObserver(
        (entries) => entries.forEach((e) => {
          if (e.isIntersecting) {
            e.target.classList.add('reveal-in');
            observer.unobserve(e.target);
          }
        }),
        { threshold: 0.08, rootMargin: '0px 0px -48px 0px' }
      );
      document
        .querySelectorAll('section:not(#hero)')
        .forEach((el) => {
          el.classList.add('reveal-init');
          observer.observe(el);
        });
    </script>
  </body>
</html>

---
import BaseLayout from '@layouts/BaseLayout.astro';
import Nav from '@components/Nav.astro';
import Footer from '@components/Footer.astro';
import { SITE } from '@data/site';
---

<BaseLayout
  title="הצהרת נגישות — גל עופרי פיזיותרפיה"
  description="הצהרת הנגישות של אתר גל עופרי לפיזיותרפיה — רמת נגישות, טכנולוגיות נתמכות, וכיצד לדווח על בעיות."
  bodyClass="!pb-0"
>
  <Nav slot="header" />

  <section class="section-padding bg-neutral-50">
    <div class="container-prose max-w-3xl">

      <h1 class="font-serif text-3xl font-bold text-teal-700 md:text-4xl">הצהרת נגישות</h1>
      <p class="mt-2 text-sm text-neutral-500">עודכן לאחרונה: מאי 2026</p>

      <div class="mt-10 space-y-10 leading-relaxed text-neutral-700">

        <section>
          <h2 class="mb-3 font-serif text-xl font-bold text-neutral-800">מחויבות לנגישות</h2>
          <p>קליניקת גל עופרי לפיזיותרפיה מחויבת להנגשת האתר לכלל האוכלוסייה, לרבות אנשים עם מוגבלות. האתר מיועד לעמוד בדרישות תקן ישראלי IS 5568 ברמת WCAG 2.0 AA, בהתאם לתקנות שוויון זכויות לאנשים עם מוגבלות (התאמות נגישות לשירות), התשע"ג–2013.</p>
        </section>

        <section>
          <h2 class="mb-3 font-serif text-xl font-bold text-neutral-800">מה כלול בנגישות האתר</h2>
          <ul class="space-y-2 list-disc list-inside text-sm">
            <li>ניווט מלא במקלדת בלבד — ללא צורך בעכבר</li>
            <li>תאימות לקוראי מסך (NVDA, VoiceOver) — שימוש ב-ARIA labels ו-landmark roles לאורך כל האתר</li>
            <li>קישור דילוג לתוכן הראשי (Skip to main content) בראש כל עמוד</li>
            <li>כותרות מסודרות בהיררכיה ברורה (H1–H3) בכל עמוד</li>
            <li>תיאורי alt לכל התמונות</li>
            <li>ניהול פוקוס בתפריט הנייד עם תמיכה ב-aria-modal ו-inert</li>
            <li>הודעות שגיאה ואישור נגישות בטפסים (aria-live, aria-invalid, aria-describedby)</li>
            <li>תמיכה בהגדרת prefers-reduced-motion — האנימציות מבוטלות לפי בחירת המשתמש</li>
            <li>ניגוד צבעים ברמת WCAG AA ברכיבי הטקסט הראשיים</li>
            <li>האתר בנוי ב-HTML סמנטי עם <code class="rounded bg-neutral-100 px-1 text-xs">lang="he" dir="rtl"</code></li>
            <li>תפריט נייד נגיש עם aria-expanded, aria-controls, ועצירה ב-Escape</li>
            <li>styles מובהקים למצב focus-visible על כל הרכיבים האינטראקטיביים</li>
          </ul>
        </section>

        <section>
          <h2 class="mb-3 font-serif text-xl font-bold text-neutral-800">דפדפנים וטכנולוגיות נתמכות</h2>
          <p>האתר נבדק ונתמך בדפדפנים הנפוצים (Chrome, Firefox, Safari, Edge) בגרסאות עדכניות, הן במחשב שולחני והן במכשירים ניידים.</p>
        </section>

        <section>
          <h2 class="mb-3 font-serif text-xl font-bold text-neutral-800">פנייה בנושא נגישות</h2>
          <p>נתקלתם בבעיית נגישות? נשמח לשמוע ולתקן. אנא פנו אלינו:</p>
          <ul class="mt-3 space-y-1 text-sm">
            <li><strong class="font-semibold text-neutral-800">אימייל:</strong> <a href={`mailto:${SITE.email}`} class="text-teal-700 underline-offset-2 hover:underline">{SITE.email}</a></li>
            <li><strong class="font-semibold text-neutral-800">טלפון:</strong> <a href={`tel:${SITE.phoneE164}`} dir="ltr" class="text-teal-700 underline-offset-2 hover:underline">{SITE.phone}</a></li>
          </ul>
          <p class="mt-4 text-sm text-neutral-500">נשתדל לטפל בפנייה תוך 5 ימי עסקים.</p>
        </section>

        <section>
          <h2 class="mb-3 font-serif text-xl font-bold text-neutral-800">גורם אחראי ותאריך בדיקה</h2>
          <p>הגורם האחראי לנגישות האתר: גל עופרי.<br />
          תאריך בדיקת נגישות אחרון: מאי 2026.</p>
        </section>

      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

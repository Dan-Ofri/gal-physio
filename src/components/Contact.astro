---
import { SITE } from '@data/site';

const contactItems = [
  {
    id: 'phone',
    label: 'טלפון',
    value: SITE.phone,
    href: `tel:${SITE.phoneE164}`,
    ariaLabel: `חייגו לגל עופרי: ${SITE.phone}`,
    iconPath:
      'M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.33a2 2 0 0 1 2-1.72h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.94 6.94l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z',
  },
  {
    id: 'email',
    label: 'אימייל',
    value: SITE.email,
    href: `mailto:${SITE.email}`,
    ariaLabel: `שלחו אימייל לגל עופרי: ${SITE.email}`,
    iconPath:
      'M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6',
  },
  {
    id: 'location',
    label: 'מיקום',
    value: `${SITE.address.street}, ${SITE.address.cityHebrew}`,
    href: `https://maps.google.com/?q=${encodeURIComponent(SITE.address.street + ', ' + SITE.address.cityHebrew)}`,
    ariaLabel: `פתח מפה — ${SITE.address.street}, ${SITE.address.cityHebrew}`,
    iconPath:
      'M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z M12 10a2 2 0 1 0 0-4 2 2 0 0 0 0 4z',
  },
];
---

<section
  id="contact"
  aria-labelledby="contact-heading"
  class="relative overflow-hidden section-padding bg-[#5c2232]"
>
  <!-- Background blobs -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0">
    <div class="absolute -top-32 -end-32 h-[500px] w-[500px] rounded-full bg-teal-900/40 blur-[120px]"></div>
    <div class="absolute -bottom-32 -start-32 h-[400px] w-[400px] rounded-full bg-teal-800/20 blur-[100px]"></div>
  </div>

  <div class="container-prose relative z-10">

    <!-- Section header (centred, above the 2-col grid) -->
    <div class="mx-auto mb-12 max-w-2xl text-center">
      <p class="text-xs font-semibold tracking-wide text-[#de9256]" aria-hidden="true">
        צור קשר
      </p>
      <h2
        id="contact-heading"
        class="mt-3 font-serif text-3xl font-bold text-white md:text-4xl"
      >
        בואו נתחיל בתהליך ביחד
      </h2>
    </div>

    <!-- 2-column grid: info (right in RTL) + form card (left in RTL) -->
    <div class="grid items-center gap-10 lg:grid-cols-2 lg:gap-12">

      <!-- ── Contact info (first in DOM = right column in RTL) ── -->
      <div class="flex flex-col gap-8">

        <!-- Info items -->
        <div class="space-y-5" role="list" aria-label="פרטי יצירת קשר">
          {contactItems.map((item) => (
            <div role="listitem" class="flex items-center gap-3">
              <div
                class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-white/10 ring-1 ring-white/20"
                aria-hidden="true"
              >
                <svg
                  class="h-5 w-5 text-teal-300"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  aria-hidden="true"
                  set:html={item.iconPath.split(' M').map((d, i) => `<path d="${i === 0 ? d : 'M' + d}"/>`).join('')}
                />
              </div>
              <div>
                <p class="text-xs font-semibold tracking-wide text-neutral-400">
                  {item.label}
                </p>
                <a
                  href={item.href}
                  aria-label={item.ariaLabel}
                  class="mt-0.5 block text-base font-medium text-white transition-colors hover:text-teal-300"
                  dir={item.id === 'phone' ? 'ltr' : undefined}
                  {...(item.id === 'location' ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                >
                  {item.value}
                </a>
              </div>
            </div>
          ))}
        </div>

        <!-- Navigation buttons -->
        <div class="flex flex-wrap gap-2" aria-label="כלי ניווט לקליניקה">
          <a
            href={`https://maps.google.com/?q=${encodeURIComponent(SITE.address.street + ', ' + SITE.address.cityHebrew)}`}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-xl border border-white/20 px-3.5 py-2 text-xs font-medium text-white/70 transition-all duration-200 hover:border-white/40 hover:text-white"
            aria-label="ניווט לקליניקה ב-Google Maps"
          >
            <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            Google Maps
          </a>
          <a
            href="https://waze.com/ul?q=Bloch%2038%20Tel%20Aviv"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1.5 rounded-xl border border-white/20 px-3.5 py-2 text-xs font-medium text-white/70 transition-all duration-200 hover:border-white/40 hover:text-white"
            aria-label="ניווט לקליניקה ב-Waze"
          >
            <svg class="h-3.5 w-3.5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.54 6.63C19.07 3.24 15.69 1 12 1 6.48 1 2 5.48 2 11c0 3.05 1.37 5.8 3.54 7.65L4.5 21l2.68-1.07C8.14 20.6 10.02 21 12 21c5.52 0 10-4.48 10-10 0-1.55-.35-3.01-.96-4.31L20.54 6.63zM12 19c-1.77 0-3.47-.47-4.93-1.31L6.5 18l.36-1.47C5.12 15.38 4 13.29 4 11c0-4.41 3.59-8 8-8 3.07 0 5.79 1.75 7.14 4.33.43.81.66 1.71.66 2.67 0 3.55-2.74 6.62-6.11 7.75L12 19zm2.5-9.5c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1zm-5 0c-.55 0-1 .45-1 1s.45 1 1 1 1-.45 1-1-.45-1-1-1zm2.5 5c-1.48 0-2.75-.81-3.45-2h6.9c-.7 1.19-1.97 2-3.45 2z"/>
            </svg>
            Waze
          </a>
        </div>

      </div>

      <!-- ── Contact form (second in DOM = left column in RTL) ── -->
      <div class="rounded-3xl bg-white px-6 py-8 shadow-[0_2px_20px_-4px_rgb(0_0_0_/_0.09)] ring-1 ring-neutral-200/60 lg:px-8 lg:py-8">

        <h3 class="font-serif text-2xl font-bold text-neutral-900">השאירו פרטים ואחזור אליכם בהקדם</h3>
        <p class="mt-1.5 text-sm text-neutral-600">ספרו לי על הכאב שלכם — ונמצא יחד את הפתרון הנכון.</p>

        <!-- Success state (hidden until form submit) -->
        <div
          id="form-success"
          class="hidden py-10 text-center"
          role="alert"
          aria-live="polite"
        >
          <div class="mx-auto mb-5 flex h-16 w-16 items-center justify-center rounded-full bg-teal-50 ring-1 ring-teal-200" aria-hidden="true">
            <svg class="h-8 w-8 text-teal-600" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <h3 class="font-serif text-xl font-bold text-neutral-900">הפנייה נשלחה!</h3>
          <p class="mt-2 text-sm leading-relaxed text-neutral-600">נחזור אליכם תוך יום עסקים אחד.<br/>לתגובה מהירה יותר — שלחו הודעה בוואטסאפ.</p>
          <a
            href={SITE.whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 inline-flex items-center gap-2 rounded-full bg-[#25D366]/10 px-5 py-2.5 text-sm font-semibold text-[#25D366] ring-1 ring-[#25D366]/30 transition hover:bg-[#25D366]/20"
            aria-label="שלחו הודעה מהירה בוואטסאפ"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
            </svg>
            המשיכו בוואטסאפ
          </a>
        </div>

        <!-- Error state -->
        <div
          id="form-error-state"
          class="hidden mt-4 rounded-2xl bg-red-50 px-5 py-4 text-sm text-red-700 ring-1 ring-red-200"
          role="alert"
          aria-live="assertive"
          tabindex="-1"
        >
          שגיאה בשליחת הטופס. אנא נסו שוב, או פנו אלינו ישירות בוואטסאפ.
        </div>

        <form
          id="contact-form"
          novalidate
          aria-label="טופס יצירת קשר"
          class="mt-6 space-y-5"
        >
          <!-- Web3Forms access key — get yours free at web3forms.com/create -->
          <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_ACCESS_KEY" />
          <input type="hidden" name="subject" value="פנייה חדשה מהאתר — גל עופרי פיזיותרפיה" />

          <!-- Name -->
          <div>
            <label for="contact-name" class="sr-only">שם מלא</label>
            <input
              type="text"
              id="contact-name"
              name="name"
              autocomplete="name"
              required
              aria-required="true"
              placeholder="שם מלא"
              class="form-input"
            />
            <p class="form-error hidden" id="name-error" role="alert"></p>
          </div>

          <!-- Phone -->
          <div>
            <label for="contact-phone" class="sr-only">מספר טלפון</label>
            <input
              type="tel"
              id="contact-phone"
              name="phone"
              autocomplete="tel"
              required
              aria-required="true"
              placeholder="מספר טלפון"
              dir="ltr"
              class="form-input text-start placeholder:text-right"
            />
            <p class="form-error hidden" id="phone-error" role="alert"></p>
          </div>

          <!-- Message -->
          <div>
            <label for="contact-message" class="sr-only">הודעה</label>
            <textarea
              id="contact-message"
              name="message"
              rows={3}
              required
              aria-required="true"
              placeholder="ספרו לי קצת על הכאב או הצורך שלכם..."
              class="form-input resize-none"
            ></textarea>
            <p class="form-error hidden" id="message-error" role="alert"></p>
          </div>

          <!-- Submit -->
          <div class="pt-2">
            <button
              type="submit"
              id="submit-btn"
              class="btn-primary w-full py-3.5"
              aria-label="שלחו את הפנייה לגל עופרי"
            >
              <span id="submit-text">שלחו הודעה</span>
              <svg
                id="submit-spinner"
                class="hidden h-4 w-4 animate-spin"
                viewBox="0 0 24 24"
                fill="none"
                aria-hidden="true"
              >
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8V0C5.373 0 0 5.373 0 12h4z"/>
              </svg>
            </button>
            <p class="mt-3 text-center text-xs text-neutral-600">
              המידע נשמר בפרטיות מלאה ואינו מועבר לצד שלישי
            </p>
          </div>

        </form>

      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const successEl = document.getElementById('form-success')!;
  const errorEl = document.getElementById('form-error-state')!;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const submitText = document.getElementById('submit-text')!;
  const submitSpinner = document.getElementById('submit-spinner')!;

  function showError(inputId: string, errorId: string, message: string) {
    const input = document.getElementById(inputId) as HTMLElement;
    const error = document.getElementById(errorId)!;
    input.setAttribute('aria-invalid', 'true');
    input.setAttribute('aria-describedby', errorId);
    error.textContent = message;
    error.classList.remove('hidden');
  }

  function clearError(inputId: string, errorId: string) {
    const input = document.getElementById(inputId) as HTMLElement;
    const error = document.getElementById(errorId)!;
    input.removeAttribute('aria-invalid');
    input.removeAttribute('aria-describedby');
    error.textContent = '';
    error.classList.add('hidden');
  }

  function validate(): boolean {
    let valid = true;
    const name = (document.getElementById('contact-name') as HTMLInputElement).value.trim();
    const phone = (document.getElementById('contact-phone') as HTMLInputElement).value.trim();
    const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value.trim();

    clearError('contact-name', 'name-error');
    clearError('contact-phone', 'phone-error');
    clearError('contact-message', 'message-error');

    if (!name) {
      showError('contact-name', 'name-error', 'שם מלא הוא שדה חובה.');
      valid = false;
    }
    if (!phone) {
      showError('contact-phone', 'phone-error', 'מספר טלפון הוא שדה חובה.');
      valid = false;
    } else if (!/^[\d\s\-+()]{7,15}$/.test(phone)) {
      showError('contact-phone', 'phone-error', 'אנא הכניסו מספר טלפון תקין.');
      valid = false;
    }
    if (!message) {
      showError('contact-message', 'message-error', 'הודעה היא שדה חובה.');
      valid = false;
    }
    return valid;
  }

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!validate()) return;

    submitBtn.disabled = true;
    submitText.textContent = 'שולח...';
    submitSpinner.classList.remove('hidden');
    errorEl.classList.add('hidden');

    try {
      const accessKey = (form.querySelector('[name="access_key"]') as HTMLInputElement).value;
      const name = (document.getElementById('contact-name') as HTMLInputElement).value.trim();
      const phone = (document.getElementById('contact-phone') as HTMLInputElement).value.trim();
      const message = (document.getElementById('contact-message') as HTMLTextAreaElement).value.trim();

      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', Accept: 'application/json' },
        body: JSON.stringify({
          access_key: accessKey,
          subject: 'פנייה חדשה מהאתר — גל עופרי פיזיותרפיה',
          name,
          phone,
          message,
        }),
      });

      if (!res.ok) throw new Error('Submission failed');

      form.classList.add('hidden');
      errorEl.classList.add('hidden');
      successEl.classList.remove('hidden');
      successEl.focus();
    } catch {
      submitBtn.disabled = false;
      submitText.textContent = 'שלחו הודעה';
      submitSpinner.classList.add('hidden');
      errorEl.classList.remove('hidden');
      errorEl.focus();
    }
  });
</script>

---
interface Testimonial {
  id: number;
  text: string;
  author: string;
  role: string;
  initials: string;
  service: string;
}

const testimonials: Testimonial[] = [
  {
    id: 1,
    text: 'כספורטאי, היה לי חשוב למצוא מישהי שמבינה את הרצון לחזור למגרש. גל בנתה לי תוכנית הדרגתית ומקצועית שהחזירה לי את הביטחון בתנועה.',
    author: 'רן כ.',
    role: 'רץ אמן, גיל 32',
    initials: 'רכ',
    service: 'שיקום ספורט',
  },
  {
    id: 2,
    text: 'הגעתי עם כאב כרוני שהגביל אותי ביומיום. הגישה של גל הייתה שונה – היא הקשיבה, הסבירה כל שלב ונתנה לי כלים אמיתיים להתמודד עם העומס.',
    author: 'מיכל א.',
    role: 'מנהלת שיווק, גיל 45',
    initials: 'מא',
    service: 'טיפול בכאב',
  },
  {
    id: 3,
    text: 'הגענו עם הבת שלנו אחרי פציעה באימונים. המקצועיות של גל יחד עם הגישה המרגיעה שלה לבני נוער עשו את כל ההבדל. היום היא חוזרת להתאמן בחיוך.',
    author: 'שרה מ.',
    role: 'אמא של מטופלת',
    initials: 'שמ',
    service: 'ליווי בני נוער',
  },
];

---

<section
  id="testimonials"
  aria-labelledby="testimonials-heading"
  class="section-padding bg-white"
>
  <div class="container-prose">

    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-accent-gold" aria-hidden="true">
        מה אומרים המטופלים
      </p>
      <h2
        id="testimonials-heading"
        class="mt-3 font-serif text-3xl font-bold text-teal-700 md:text-4xl"
      >
        מטופלים מספרים
      </h2>
      <p class="mt-4 leading-relaxed text-neutral-500">
        לכל אחד ואחת יש את הקצב והדרך שלהם. הנה כמה רגעים מהתהליכים שעברנו יחד.
      </p>
    </div>

    <!-- Testimonial cards grid -->
    <div
      class="mt-14 grid gap-6 md:grid-cols-3"
      role="list"
      aria-label="המלצות מטופלים"
    >
      {testimonials.map((t) => (
        <article
          role="listitem"
          class="group flex flex-col rounded-3xl bg-neutral-50 p-9 ring-1 ring-neutral-100 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-card-hover hover:ring-teal-100"
          aria-label={`המלצה מ-${t.author}`}
        >
          <!-- Blockquote -->
          <blockquote class="mt-5 flex-1">
            <!-- Decorative opening quote mark -->
            <svg
              aria-hidden="true"
              class="mb-3 h-6 w-6 text-accent-gold/40 transition-colors duration-300 group-hover:text-accent-gold/70"
              viewBox="0 0 24 24"
              fill="currentColor"
            >
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z" />
            </svg>
            <p class="text-sm leading-relaxed text-neutral-600">
              {t.text}
            </p>
          </blockquote>

          <!-- Divider -->
          <div aria-hidden="true" class="my-6 h-px bg-neutral-200/70"></div>

          <!-- Author -->
          <footer class="flex items-center gap-3">
            <!-- Avatar with initials -->
            <div
              class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-teal-100 text-sm font-bold text-teal-700"
              aria-hidden="true"
            >
              {t.initials}
            </div>
            <div class="min-w-0">
              <cite class="block text-sm font-semibold not-italic text-neutral-800">
                {t.author}
              </cite>
              <p class="text-xs text-neutral-400">{t.role}</p>
            </div>
            <!-- Service tag -->
            <span
              class="ms-auto shrink-0 rounded-full bg-teal-50 px-2.5 py-1 text-xs font-medium text-teal-700"
              aria-label={`שירות: ${t.service}`}
            >
              {t.service}
            </span>
          </footer>
        </article>
      ))}
    </div>

  </div>
</section>

---
interface Service {
  id: string;
  /** Inner SVG elements only (paths, polylines, etc.) — rendered via set:html */
  iconHTML: string;
  iconAriaLabel: string;
  title: string;
  tagline: string;
  description: string;
  keywords: readonly string[];
  featured?: boolean;
}

const services: Service[] = [
  {
    id: 'sports-rehab',
    iconHTML: `<polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" stroke-linecap="round" stroke-linejoin="round"/>`,
    iconAriaLabel: 'אייקון ברק — ביצועים ואנרגיה ספורטיבית',
    title: 'שיקום ספורטאים ושיפור ביצועים',
    tagline: 'חזרה לאימונים — מהירה, בטוחה, ואפילו חזקה יותר',
    description:
      'כלשעבר ספורטאית תחרותית, אני מכירה את שפת הגוף הספורטיבי מקרוב. הטיפול משלב שיקום ספורט ייחודי, מניעת פציעות חוזרות ותוכנית חזרה מדורגת לביצועים מלאים.',
    keywords: ['שיקום ספורט', 'פציעות ספורט', 'שיפור ביצועים ספורטיביים', 'פיזיותרפיה לספורטאים'],
  },
  {
    id: 'pain-ortho',
    iconHTML: `
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/>
      <line x1="12" y1="8" x2="12" y2="16" stroke-linecap="round"/>
      <line x1="8"  y1="12" x2="16" y2="12" stroke-linecap="round"/>
    `,
    iconAriaLabel: 'אייקון מגן עם צלב — הגנה וריפוי',
    title: 'טיפול בכאב ופציעות אורטופדיות',
    tagline: 'לרוץ, לאמן ולהרים ילדים — בלי כאב',
    description:
      'כאב גב, ברך, כתף או צוואר — אמצא את שורש הבעיה ואבנה איתך דרך ברורה לשגרה המלאה: לרוץ, להתאמן, לשחק עם הילדים — ולחיות ללא כאב ופחד.',
    keywords: ['טיפול בכאב', 'שיקום אורטופדי', 'פציעות אורטופדיות', 'כאב גב', 'כאב ברך', 'כאב כתף'],
    featured: true,
  },
  {
    id: 'youth-adults',
    iconHTML: `
      <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round"/>
      <circle cx="9" cy="7" r="4"/>
      <path d="M23 21v-2a4 4 0 0 0-3-3.87" stroke-linecap="round"/>
      <path d="M16 3.13a4 4 0 0 1 0 7.75"  stroke-linecap="round"/>
    `,
    iconAriaLabel: 'אייקון אנשים — ליווי לכל הגילאים',
    title: 'ליווי בני נוער ומבוגרים',
    tagline: 'טיפול מותאם אישית לכל שלב בחיים',
    description:
      'מבני נוער בעיצומה של הצמיחה ועד מבוגרים שרוצים להישאר פעילים ועצמאיים — כל תוכנית טיפול מותאמת לגיל, לצרכים ולמטרות הייחודיות שלך.',
    keywords: ['פיזיותרפיה לבני נוער', 'פיזיותרפיה למבוגרים', 'שיקום בכל גיל'],
  },
];
---

<section
  id="services"
  aria-labelledby="services-heading"
  class="relative section-padding overflow-hidden bg-neutral-50"
>
  <!-- Subtle decorative radial at corner -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-24 end-0 h-[480px] w-[480px] rounded-full bg-teal-50/60 blur-3xl"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-24 start-0 h-[320px] w-[320px] rounded-full bg-teal-50/40 blur-3xl"
  ></div>

  <div class="container-prose relative z-10">

    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold uppercase tracking-widest text-teal-700" aria-hidden="true">
        השירותים שלי
      </p>
      <h2
        id="services-heading"
        class="mt-3 font-serif text-3xl font-bold text-neutral-900 md:text-4xl"
      >
        במה אני יכולה לעזור לך?
      </h2>
      <p class="mt-4 leading-relaxed text-neutral-500">
        כל טיפול מותאם אישית לגוף שלך ולמטרות שלך — כי אין שתי פציעות זהות, ואין שני אנשים זהים.
      </p>
    </div>

    <!-- Service cards -->
    <div
      class="mt-14 grid gap-6 md:grid-cols-3"
      role="list"
      aria-label="שירותי הפיזיותרפיה שלי"
    >
      {services.map((service) => (
        <article
          role="listitem"
          class="group flex flex-col rounded-2xl bg-white p-10 ring-1 ring-neutral-200 transition-all duration-300 ease-out hover:-translate-y-0.5 hover:ring-teal-200/70 hover:shadow-[0_4px_20px_-4px_rgb(0_0_0_/_0.07)]"
        >
          <!-- Icon container -->
          <div
            class="mb-7 flex h-12 w-12 items-center justify-center rounded-xl bg-teal-50 transition-colors duration-300 group-hover:bg-teal-100"
            role="img"
            aria-label={service.iconAriaLabel}
          >
            <svg
              class="h-5 w-5 text-teal-700"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
              set:html={service.iconHTML}
            />
          </div>

          <!-- Title -->
          <h3 class="font-serif text-xl font-bold leading-snug text-neutral-900">
            {service.title}
          </h3>

          <!-- Tagline -->
          <p class="mt-1.5 text-sm font-semibold text-teal-700">
            {service.tagline}
          </p>

          <!-- Description -->
          <p class="mt-4 flex-1 text-sm leading-relaxed text-neutral-500">
            {service.description}
          </p>

          <!-- SEO keyword list — hidden visually -->
          <ul class="sr-only" aria-hidden="true">
            {service.keywords.map((k) => <li>{k}</li>)}
          </ul>

          <!-- Divider -->
          <div aria-hidden="true" class="my-7 h-px bg-neutral-100"></div>

          <!-- Card CTA -->
          <a
            href="#contact"
            class="inline-flex items-center gap-2 text-sm font-semibold text-teal-700 transition-all duration-200 hover:text-teal-900 group-hover:gap-3"
            aria-label={`לתיאום ייעוץ ראשוני עבור ${service.title}`}
          >
            לתיאום ייעוץ ראשוני
            <svg
              class="h-4 w-4 shrink-0 transition-transform duration-200 group-hover:-translate-x-0.5"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2.5"
              aria-hidden="true"
            >
              <polyline points="15 18 9 12 15 6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </article>
      ))}
    </div>

  </div>
</section>

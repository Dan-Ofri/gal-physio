---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

import orthoImg    from '../assets/service-ortho-ref.png';
import sportsImg   from '../assets/service-sports.jpeg';
import preventImg  from '../assets/service-preventive-ref.png';

interface Service {
  id: string;
  image: ImageMetadata;
  imageAlt: string;
  imagePosition: string;
  title: string;
  description: string;
  keywords: readonly string[];
}

const services: Service[] = [
  {
    id: 'ortho-rehab',
    image: orthoImg,
    imageAlt: 'פיזיותרפיסטית מבצעת טיפול ידני בגב — שיקום אורתופדי',
    imagePosition: 'object-center',
    title: 'שיקום אורתופדי',
    description:
      'טיפול בכאבי גב, צוואר ומפרקים, וליווי מקצועי בתהליכי שיקום לאחר פציעות או ניתוחים — לחזרה מלאה ובטוחה לשגרה.',
    keywords: ['שיקום אורתופדי', 'כאב גב', 'כאב צוואר', 'שיקום מפרקים', 'שיקום לאחר ניתוח'],
  },
  {
    id: 'sports-rehab',
    image: sportsImg,
    imageAlt: 'גל עופרי מטפלת בספורטאי צעיר בחדר טיפולים — שיקום ספורטאים ושיפור ביצועים',
    imagePosition: 'object-center',
    title: 'שיקום ספורטאים ושיפור ביצועים',
    description:
      'אבחון פציעות ספורט, שיפור טכניקת תנועה ובניית תוכנית חזרה מדורגת לאימונים ולתחרות, תוך מניעת פציעות חוזרות.',
    keywords: ['שיקום ספורט', 'פציעות ספורט', 'שיפור ביצועים ספורטיביים', 'פיזיותרפיה לספורטאים'],
  },
  {
    id: 'preventive',
    image: preventImg,
    imageAlt: 'פיזיותרפיסטית מבצעת הערכת יציבה לפציינטית עומדת — פיזיותרפיה מניעתית',
    imagePosition: 'object-center',
    title: 'פיזיותרפיה מניעתית ותחזוקת הגוף',
    description:
      'שיפור היציבה, איזון עומסים יומיומיים ובניית חוסן גופני ארוך טווח באמצעות תרגול מותאם אישית לצרכים שלך.',
    keywords: ['פיזיותרפיה מניעתית', 'שיפור יציבה', 'חוסן גופני', 'תרגול מותאם אישית'],
  },
];
---

<section
  id="services"
  aria-labelledby="services-heading"
  class="relative section-padding overflow-hidden bg-neutral-50"
>
  <!-- Subtle decorative radials -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-24 end-0 h-[480px] w-[480px] rounded-full bg-neutral-100/60 blur-3xl"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-24 start-0 h-[320px] w-[320px] rounded-full bg-neutral-100/40 blur-3xl"
  ></div>

  <div class="container-prose relative z-10">

    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold tracking-wide text-teal-600" aria-hidden="true">
        השירותים שלי
      </p>
      <h2
        id="services-heading"
        class="mt-3 font-serif text-3xl font-bold text-teal-700 md:text-4xl"
      >
        איך אני יכולה לעזור לך?
      </h2>
      <p class="mt-4 leading-relaxed text-neutral-600">
        מטיפול בכאב ועד שיקום ספורט — אני כאן לעזור לכם לחזור לנוע בחופשיות, לתפקד ביומיום ולהרגיש טוב בגוף שלכם.
      </p>
    </div>

    <!-- Service cards -->
    <div
      class="mt-10 grid gap-6 md:grid-cols-3"
      role="list"
      aria-label="שירותי הפיזיותרפיה שלי"
    >
      {services.map((service) => (
        <article
          role="listitem"
          class="group flex h-full flex-col overflow-hidden rounded-2xl bg-white ring-1 ring-neutral-200 transition-all duration-300 ease-out hover:-translate-y-0.5 hover:ring-teal-200/70 hover:shadow-[0_4px_20px_-4px_rgb(0_0_0_/_0.08)]"
        >
          <!-- Photo -->
          <div class="overflow-hidden">
            <Image
              src={service.image}
              alt={service.imageAlt}
              width={480}
              height={360}
              loading="lazy"
              class={`w-full aspect-[4/3] object-cover transition-transform duration-500 ease-out group-hover:scale-[1.04] ${service.imagePosition}`}
            />
          </div>

          <!-- Text content -->
          <div class="flex flex-1 flex-col p-7">
            <h3 class="font-serif text-xl font-bold leading-snug text-neutral-900">
              {service.title}
            </h3>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-neutral-600">
              {service.description}
            </p>
            <ul class="sr-only" aria-hidden="true">
              {service.keywords.map((k) => <li>{k}</li>)}
            </ul>
          </div>

        </article>
      ))}
    </div>

    <!-- Section CTA -->
    <div class="mt-14 text-center">
      <a
        href="#contact"
        class="btn-primary px-10 py-4 text-base"
        aria-label="לתיאום ייעוץ ראשוני עם גל עופרי פיזיותרפיה"
      >
        <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-linejoin="round"/>
          <path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/>
        </svg>
        לתיאום ייעוץ ראשוני
      </a>
    </div>

  </div>
</section>

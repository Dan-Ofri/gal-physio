---
interface Service {
  id: string;
  /** Inner SVG elements only (paths, polylines, etc.) — rendered via set:html */
  iconHTML: string;
  iconAriaLabel: string;
  title: string;
  description: string;
  keywords: readonly string[];
}

const services: Service[] = [
  {
    id: 'ortho-rehab',
    iconHTML: `
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke-linecap="round" stroke-linejoin="round"/>
      <line x1="12" y1="8" x2="12" y2="16" stroke-linecap="round"/>
      <line x1="8"  y1="12" x2="16" y2="12" stroke-linecap="round"/>
    `,
    iconAriaLabel: 'אייקון מגן — שיקום אורתופדי ומפרקי',
    title: 'שיקום אורתופדי ומפרקי',
    description:
      'טיפול בכאבי גב, צוואר ומפרקים, וליווי מקצועי בתהליכי שיקום לאחר פציעות או ניתוחים — לחזרה מלאה ובטוחה לשגרה.',
    keywords: ['שיקום אורתופדי', 'כאב גב', 'כאב צוואר', 'שיקום מפרקים', 'שיקום לאחר ניתוח'],
  },
  {
    id: 'sports-rehab',
    iconHTML: `<polyline points="13 2 3 14 12 14 11 22 21 10 12 10 13 2" stroke-linecap="round" stroke-linejoin="round"/>`,
    iconAriaLabel: 'אייקון ברק — שיקום ספורטאים',
    title: 'שיקום ספורטאים ושיפור ביצועים',
    description:
      'אבחון פציעות ספורט, שיפור טכניקת תנועה ובניית תוכנית חזרה מדורגת לאימונים ולתחרות, תוך מניעת פציעות חוזרות.',
    keywords: ['שיקום ספורט', 'פציעות ספורט', 'שיפור ביצועים ספורטיביים', 'פיזיותרפיה לספורטאים'],
  },
  {
    id: 'preventive',
    iconHTML: `<polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke-linecap="round" stroke-linejoin="round"/>`,
    iconAriaLabel: 'אייקון פעילות — פיזיותרפיה מניעתית',
    title: 'פיזיותרפיה מניעתית ותחזוקת הגוף',
    description:
      'שיפור היציבה, איזון עומסים יומיומיים ובניית חוסן גופני ארוך טווח באמצעות תרגול מותאם אישית לצרכים שלך.',
    keywords: ['פיזיותרפיה מניעתית', 'שיפור יציבה', 'חוסן גופני', 'תרגול מותאם אישית'],
  },
];
---

<section
  id="services"
  aria-labelledby="services-heading"
  class="relative section-padding overflow-hidden bg-neutral-50"
>
  <!-- Subtle decorative radial at corner -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -top-24 end-0 h-[480px] w-[480px] rounded-full bg-teal-50/60 blur-3xl"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-24 start-0 h-[320px] w-[320px] rounded-full bg-teal-50/40 blur-3xl"
  ></div>

  <div class="container-prose relative z-10">

    <!-- Section header -->
    <div class="mx-auto max-w-2xl text-center">
      <p class="text-xs font-semibold tracking-wide text-accent-gold" aria-hidden="true">
        השירותים שלי
      </p>
      <h2
        id="services-heading"
        class="mt-3 font-serif text-3xl font-bold text-teal-700 md:text-4xl"
      >
        איך אני יכולה לעזור לך?
      </h2>
      <p class="mt-4 leading-relaxed text-neutral-500">
        מטיפול בכאב ועד שיקום ספורט — אני כאן לעזור לכם לחזור לנוע בחופשיות, לתפקד ביומיום ולהרגיש טוב בגוף שלכם.
      </p>
    </div>

    <!-- Service cards -->
    <div
      class="mt-10 grid gap-6 md:grid-cols-3"
      role="list"
      aria-label="שירותי הפיזיותרפיה שלי"
    >
      {services.map((service) => (
        <article
          role="listitem"
          class="group flex h-full flex-col rounded-2xl bg-white p-8 ring-1 ring-neutral-200 transition-all duration-300 ease-out hover:-translate-y-0.5 hover:ring-teal-200/70 hover:shadow-[0_4px_20px_-4px_rgb(0_0_0_/_0.07)]"
        >
          <!-- Icon container -->
          <div
            class="mb-6 flex h-11 w-11 items-center justify-center rounded-xl bg-teal-50 transition-colors duration-300 group-hover:bg-teal-100"
            role="img"
            aria-label={service.iconAriaLabel}
          >
            <svg
              class="h-5 w-5 text-teal-700"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
              set:html={service.iconHTML}
            />
          </div>

          <!-- Title -->
          <h3 class="font-serif text-xl font-bold leading-snug text-neutral-900">
            {service.title}
          </h3>

          <!-- Description -->
          <p class="mt-3 flex-1 text-sm leading-relaxed text-neutral-600">
            {service.description}
          </p>

          <!-- Card CTA -->
          <a
            href="#contact"
            class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-teal-700 transition-colors hover:text-teal-600"
            aria-label={`לפגישת ייעוץ על ${service.title}`}
          >
            לתיאום פגישה
            <svg class="h-3.5 w-3.5 rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
              <polyline points="9 18 15 12 9 6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>

          <!-- SEO keyword list — hidden visually -->
          <ul class="sr-only" aria-hidden="true">
            {service.keywords.map((k) => <li>{k}</li>)}
          </ul>

        </article>
      ))}
    </div>

    <!-- Section CTA -->
    <div class="mt-14 text-center">
      <a
        href="#contact"
        class="btn-primary px-10 py-4 text-base"
        aria-label="לתיאום ייעוץ ראשוני עם גל עופרי פיזיותרפיה"
      >
        <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-linejoin="round"/>
          <path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/>
        </svg>
        לתיאום ייעוץ ראשוני
      </a>
    </div>

  </div>
</section>

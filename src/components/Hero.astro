---
import { Image } from 'astro:assets';
import galPlaceholder from '../assets/gal-placeholder.svg';

const stats = [
  { value: '10+',  label: 'שנות ניסיון' },
  { value: '500+', label: 'מטופלים.ות' },
  { value: '100%', label: 'מחויבות לתוצאות' },
];
---

<section
  id="hero"
  aria-labelledby="hero-heading"
  class="relative flex min-h-svh items-center overflow-hidden bg-navy-900 pt-20"
>
  <!-- ── Decorative background blobs (aria-hidden) ── -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 select-none overflow-hidden">
    <!-- Top-start glow -->
    <div class="absolute -top-40 -end-40 h-[640px] w-[640px] rounded-full bg-teal-800/20 blur-[140px]"></div>
    <!-- Bottom-end glow -->
    <div class="absolute -bottom-48 -start-24 h-[560px] w-[560px] rounded-full bg-teal-600/10 blur-[120px]"></div>
    <!-- Subtle center lift -->
    <div class="absolute top-1/2 start-1/3 h-[400px] w-[400px] -translate-y-1/2 rounded-full bg-navy-800/40 blur-[80px]"></div>
  </div>

  <!-- ── Content grid ── -->
  <div class="container-prose relative z-10 grid items-center gap-12 py-16 lg:grid-cols-2 lg:gap-20 lg:py-24">

    <!-- Text (first in DOM = right column in RTL desktop, top in mobile) -->
    <div class="flex flex-col text-center lg:text-start">

      <!-- Eyebrow / badge -->
      <p
        class="animate-fade-up mb-6 inline-flex items-center justify-center gap-2 self-center rounded-full border border-teal-700/50 bg-teal-900/50 px-4 py-1.5 text-sm font-medium text-teal-300 lg:self-start [animation-delay:0.1s]"
      >
        <span aria-hidden="true" class="h-2 w-2 rounded-full bg-teal-400 shadow-[0_0_6px_theme(colors.teal.400)]"></span>
        פיזיותרפיה ושיקום מקצועי
      </p>

      <!-- H1 — includes "פיזיותרפיה" and "שיקום" keywords -->
      <h1
        id="hero-heading"
        class="animate-fade-up font-serif text-4xl font-bold leading-[1.15] text-white sm:text-5xl lg:text-[3.25rem] [animation-delay:0.25s]"
      >
        <span class="block text-teal-300">חזרה לתנועה מלאה,</span>
        <span class="mt-1 block">בהתאמה אישית אליך</span>
        <!-- Keyword enrichment for crawlers, invisible to sighted users -->
        <span class="sr-only">— שירותי פיזיותרפיה ושיקום</span>
      </h1>

      <!-- Sub-headline — empathy + expertise -->
      <p
        class="animate-fade-up mt-6 text-base leading-relaxed text-neutral-300 sm:text-lg lg:max-w-lg [animation-delay:0.45s]"
      >
        עם ניסיון של מעל לעשור בטיפול פיזיותרפי, אני מלווה כל מטופל.ת במסע אישי לשיקום מלא — בגישה חמה, מקצועית, ומותאמת בדיוק לצרכים שלך.
      </p>

      <!-- CTA buttons -->
      <div
        class="animate-fade-up mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row lg:justify-start [animation-delay:0.65s]"
      >
        <a
          href="#contact"
          class="btn-primary w-full sm:w-auto"
          aria-label="לתיאום ייעוץ ראשוני ופגישה ראשונה עם גל עופרי, פיזיותרפיסטית"
        >
          <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-linejoin="round"/>
            <path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          תיאום ייעוץ ראשוני
        </a>
        <a
          href="#services"
          class="btn-secondary w-full border-white/25 text-white hover:border-white hover:bg-white hover:text-navy-900 sm:w-auto"
          aria-label="לצפייה בשירותי הפיזיותרפיה ושיקום שלי"
        >
          השירותים שלי
          <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <!-- Left-pointing chevron — correct for RTL "read more" -->
            <polyline points="15 18 9 12 15 6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Trust stats -->
      <div
        class="animate-fade-up mt-10 flex items-center justify-center gap-7 border-t border-white/10 pt-8 lg:justify-start [animation-delay:0.8s]"
        aria-label="נתוני אמון"
      >
        {stats.map(({ value, label }, i) => (
          <>
            <div class="text-center lg:text-start">
              <p class="font-serif text-2xl font-bold text-white" aria-label={`${value} ${label}`}>{value}</p>
              <p class="mt-0.5 text-xs font-medium text-neutral-500">{label}</p>
            </div>
            {i < stats.length - 1 && (
              <div aria-hidden="true" class="h-8 w-px shrink-0 bg-white/15"></div>
            )}
          </>
        ))}
      </div>
    </div>

    <!-- ── Photo column (second in DOM = left column in RTL desktop, bottom in mobile) ── -->
    <div
      class="animate-fade-in flex items-end justify-center lg:justify-end [animation-delay:0.55s]"
    >
      <div class="relative w-full max-w-sm lg:max-w-none">

        <!-- Soft halo ring behind the photo -->
        <div
          aria-hidden="true"
          class="absolute -inset-6 rounded-[2.5rem] bg-gradient-to-br from-teal-600/15 via-teal-800/10 to-transparent blur-lg"
        ></div>

        <!-- Photo frame -->
        <figure class="relative overflow-hidden rounded-[2rem] ring-1 ring-white/8 shadow-card-hover">
          <!--
            Replace with a real photo:
            import { Image } from 'astro:assets';
            import galPhoto from '../assets/gal-photo.jpg';
            <Image src={galPhoto} alt="גל עופרי, פיזיותרפיסטית מוסמכת" width={480} height={600}
                   loading="eager" fetchpriority="high" class="w-full object-cover" />
          -->
          <Image
            src={galPlaceholder}
            alt="גל עופרי, פיזיותרפיסטית מוסמכת — תמונה תוחלף בקרוב"
            width={480}
            height={600}
            loading="eager"
            fetchpriority="high"
            class="block w-full"
          />
        </figure>

        <!-- Floating credential badge (bottom-start = bottom-right in RTL) -->
        <div
          class="absolute -bottom-5 -start-5 flex items-center gap-3 rounded-2xl bg-navy-800 px-4 py-3 shadow-card ring-1 ring-teal-700/40"
          role="note"
          aria-label="מוסמכת B.P.T עם רישיון מ.ב.ר"
        >
          <span aria-hidden="true" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-teal-700">
            <svg class="h-5 w-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke-linecap="round"/>
              <polyline points="22 4 12 14.01 9 11.01" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <div>
            <p class="text-sm font-semibold leading-tight text-white">מוסמכת B.P.T</p>
            <p class="text-xs leading-tight text-teal-300">רישיון מ.ב.ר</p>
          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- ── Scroll hint ── -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" aria-hidden="true">
    <div class="flex flex-col items-center gap-1.5 text-white/25">
      <span class="text-[10px] font-medium tracking-[0.2em] uppercase">גלול</span>
      <svg class="h-5 w-5 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="6 9 12 15 18 9" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>

</section>

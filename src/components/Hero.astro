---
import { Image } from 'astro:assets';
import galHero from '../assets/gal-hero.jpg';

const stats = [
  { value: 'B.P.T', label: 'מוסמכת' },
  { value: '500+', label: 'מטופלים.ות' },
  { value: '100%', label: 'מחויבות לתוצאות' },
];
---

<section
  id="hero"
  aria-labelledby="hero-heading"
  class="relative flex min-h-svh items-center overflow-hidden bg-neutral-50 pt-20"
>
  <!-- Subtle warm glow — very low opacity, clinical feel -->
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 select-none overflow-hidden">
    <div class="absolute -top-32 -end-40 h-[640px] w-[640px] rounded-full bg-teal-100/50 blur-[140px]"></div>
    <div class="absolute -bottom-48 -start-24 h-[480px] w-[480px] rounded-full bg-teal-50/70 blur-[120px]"></div>
  </div>

  <!-- ── Content grid ── -->
  <div class="container-prose relative z-10 grid items-center gap-12 py-16 lg:grid-cols-2 lg:gap-20 lg:py-24">

    <!-- Text (first in DOM = right column in RTL desktop, top in mobile) -->
    <div class="flex flex-col text-center lg:text-start">

      <!-- Eyebrow / badge -->
      <p
        class="animate-fade-up mb-6 inline-flex items-center justify-center gap-2 self-center text-sm font-medium text-teal-700 lg:self-start [animation-delay:0.1s]"
      >
        <span aria-hidden="true" class="h-1.5 w-1.5 rounded-full bg-teal-500"></span>
        פיזיותרפיה ושיקום מקצועי
      </p>

      <!-- H1 — includes "פיזיותרפיה" and "שיקום" keywords -->
      <h1
        id="hero-heading"
        class="animate-fade-up font-serif text-4xl font-bold leading-[1.15] text-neutral-900 sm:text-5xl lg:text-[3.25rem] [animation-delay:0.25s]"
      >
        <span class="block text-teal-700">חזרה לתנועה מלאה,</span>
        <span class="mt-1 block">בהתאמה אישית אליך</span>
        <span class="sr-only">— שירותי פיזיותרפיה ושיקום</span>
      </h1>

      <!-- Sub-headline -->
      <p
        class="animate-fade-up mt-6 text-base leading-relaxed text-neutral-500 sm:text-lg lg:max-w-lg [animation-delay:0.45s]"
      >
        עם ניסיון של מעל לעשור בטיפול פיזיותרפי, אני מלווה כל מטופל.ת במסע אישי לשיקום מלא — בגישה חמה, מקצועית, ומותאמת בדיוק לצרכים שלך.
      </p>

      <!-- CTA buttons -->
      <div
        class="animate-fade-up mt-8 flex flex-col items-center justify-center gap-3 sm:flex-row lg:justify-start [animation-delay:0.65s]"
      >
        <a
          href="#contact"
          class="btn-primary w-full sm:w-auto"
          aria-label="לתיאום ייעוץ ראשוני ופגישה ראשונה עם גל עופרי, פיזיותרפיסטית"
        >
          <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-linejoin="round"/>
            <path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/>
          </svg>
          תיאום ייעוץ ראשוני
        </a>
        <a
          href="#services"
          class="btn-secondary w-full sm:w-auto"
          aria-label="לצפייה בשירותי הפיזיותרפיה ושיקום שלי"
        >
          השירותים שלי
          <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <polyline points="15 18 9 12 15 6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

      <!-- Trust stats -->
      <div
        class="animate-fade-up mt-10 flex items-center justify-center gap-7 border-t border-neutral-200 pt-8 lg:justify-start [animation-delay:0.8s]"
        aria-label="נתוני אמון"
      >
        {stats.map(({ value, label }, i) => (
          <>
            <div class="text-center lg:text-start">
              <p class="font-serif text-2xl font-bold text-neutral-900" aria-label={`${value} ${label}`}>{value}</p>
              <p class="mt-0.5 text-xs font-medium text-neutral-500">{label}</p>
            </div>
            {i < stats.length - 1 && (
              <div aria-hidden="true" class="h-8 w-px shrink-0 bg-neutral-200"></div>
            )}
          </>
        ))}
      </div>
    </div>

    <!-- ── Photo column ── -->
    <div
      class="animate-fade-in flex items-end justify-center lg:justify-end [animation-delay:0.55s]"
    >
      <div class="relative w-full max-w-sm lg:max-w-none">

        <!-- Soft halo behind photo -->
        <div
          aria-hidden="true"
          class="absolute -inset-6 rounded-[2.5rem] bg-gradient-to-br from-teal-100/50 via-teal-50/30 to-transparent blur-lg"
        ></div>

        <!-- Photo frame -->
        <figure class="relative overflow-hidden rounded-[2rem] ring-1 ring-neutral-200/80 shadow-card-hover">
          <Image
            src={galHero}
            alt="גל עופרי פיזיותרפיסטית בתל אביב — טיפול פיזיותרפיה בשיקום ספורט לבני נוער"
            width={480}
            height={600}
            loading="eager"
            fetchpriority="high"
            class="block w-full object-cover object-top"
          />
        </figure>

        <!-- Floating credential badge -->
        <div
          class="absolute -bottom-5 -start-5 flex items-center gap-3 rounded-2xl bg-white px-4 py-3 shadow-card ring-1 ring-teal-200/60"
          role="note"
          aria-label="מוסמכת B.P.T עם רישיון מ.ב.ר"
        >
          <span aria-hidden="true" class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl bg-teal-100">
            <svg class="h-5 w-5 text-teal-700" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke-linecap="round"/>
              <polyline points="22 4 12 14.01 9 11.01" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
          <div>
            <p class="text-sm font-semibold leading-tight text-neutral-800">מוסמכת B.P.T</p>
            <p class="text-xs leading-tight text-neutral-500">רישיון מ.ב.ר</p>
          </div>
        </div>

      </div>
    </div>

  </div>

  <!-- ── Scroll hint ── -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2" aria-hidden="true">
    <div class="flex flex-col items-center gap-1.5 text-neutral-400/60">
      <span class="text-[10px] font-medium tracking-[0.2em] uppercase">גלול</span>
      <svg class="h-5 w-5 animate-bounce" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="6 9 12 15 18 9" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
  </div>

</section>

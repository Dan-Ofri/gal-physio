---
import { SITE } from '@data/site';

const year = new Date().getFullYear();

const navLinks = [
  { href: '#services',     label: 'שירותים' },
  { href: '#about',        label: 'אודות' },
  { href: '#testimonials', label: 'המלצות' },
  { href: '#contact',      label: 'צור קשר' },
];

const socialLinks = [
  {
    label: 'פרופיל האינסטגרם של גל עופרי',
    href: SITE.social.instagram || '#',
    iconPath:
      'M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z M17.5 6.5h.01 M7.5 2h9A5.5 5.5 0 0 1 22 7.5v9A5.5 5.5 0 0 1 16.5 22h-9A5.5 5.5 0 0 1 2 16.5v-9A5.5 5.5 0 0 1 7.5 2z',
  },
  {
    label: 'שלחו הודעה לגל עופרי בוואטסאפ',
    href: SITE.whatsappUrl,
    iconPath:
      'M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z',
    fill: true,
  },
];
---

<footer
  class="border-t-2 border-teal-100 bg-teal-50"
  aria-label="כותרת תחתונה"
>
  <div class="container-prose py-12 md:py-16">

    <!-- Top grid: brand | nav | contact -->
    <div class="grid gap-10 md:grid-cols-3 md:gap-6">

      <!-- Brand -->
      <div>
        <a
          href="/"
          aria-label={`${SITE.name} — עמוד הבית`}
          class="group inline-flex flex-col items-start"
        >
          <div class="leading-tight">
            <span class="block font-serif text-[17px] font-semibold text-neutral-900 transition-colors group-hover:text-teal-700">גל עופרי</span>
            <span class="block text-[11px] font-medium text-teal-600">פיזיותרפיה ושיקום</span>
          </div>
        </a>
        <p class="mt-4 max-w-xs text-sm leading-loose text-neutral-600">
          פיזיותרפיסטית מוסמכת בתל אביב — שיקום ספורט, טיפול בכאב, וליווי אישי לכל שלב בחיים.
        </p>
      </div>

      <!-- Nav + Contact: side-by-side on mobile, direct grid children on desktop -->
      <div class="grid grid-cols-2 gap-6 md:contents">

      <!-- Navigation links -->
      <nav aria-label="ניווט תחתון">
        <p class="mb-4 text-xs font-bold tracking-wide text-neutral-700">
          ניווט
        </p>
        <ul class="space-y-2.5">
          {navLinks.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class="text-sm text-neutral-600 underline-offset-2 transition-colors hover:text-teal-700 hover:underline"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact details -->
      <div>
        <p class="mb-4 text-xs font-bold tracking-wide text-neutral-700">
          יצירת קשר
        </p>
        <ul class="space-y-2.5" aria-label="פרטי יצירת קשר">
          <li>
            <a
              href={`tel:${SITE.phoneE164}`}
              dir="ltr"
              class="text-sm text-neutral-600 underline-offset-2 transition-colors hover:text-teal-700 hover:underline"
              aria-label={`חייגו: ${SITE.phone}`}
            >
              {SITE.phone}
            </a>
          </li>
          <li>
            <a
              href={`mailto:${SITE.email}`}
              class="text-sm text-neutral-600 underline-offset-2 transition-colors hover:text-teal-700 hover:underline"
              aria-label={`שלחו אימייל: ${SITE.email}`}
            >
              {SITE.email}
            </a>
          </li>
          <li>
            <a
              href={`https://maps.google.com/?q=${encodeURIComponent(SITE.address.street + ', ' + SITE.address.cityHebrew)}`}
              target="_blank"
              rel="noopener noreferrer"
              class="text-sm text-neutral-600 underline-offset-2 transition-colors hover:text-teal-700 hover:underline"
              aria-label={`פתח מפה — ${SITE.address.street}, ${SITE.address.cityHebrew}`}
            >
              {SITE.address.street}, {SITE.address.cityHebrew}
            </a>
          </li>
        </ul>
      </div>

      </div>{/* /nav+contact wrapper */}

    </div>

    <!-- Divider -->
    <div aria-hidden="true" class="my-10 h-px bg-teal-100"></div>

    <!-- Bottom bar: copyright + social icons -->
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-neutral-600" aria-label={`זכויות יוצרים ${year}`}>
        © {year} גל עופרי — פיזיותרפיסטית מוסמכת
      </p>

      <!-- Social icons -->
      <div class="flex items-center gap-3" role="list" aria-label="קישורי רשתות חברתיות">
        {socialLinks.map((social) => (
          <div role="listitem">
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={social.label}
              class="flex h-8 w-8 items-center justify-center rounded-full border border-neutral-200 text-neutral-500 transition-all duration-200 hover:border-teal-200 hover:text-teal-600"
            >
              <svg
                class="h-4 w-4"
                viewBox="0 0 24 24"
                fill={social.fill ? 'currentColor' : 'none'}
                stroke={social.fill ? 'none' : 'currentColor'}
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
                set:html={social.iconPath.split(' M').map((d, i) => `<path d="${i === 0 ? d : 'M' + d}"/>`).join('')}
              />
            </a>
          </div>
        ))}
      </div>
    </div>

  </div>
</footer>

---
import { SITE } from '@data/site';

const links = [
  { href: '#about',        label: 'אודות' },
  { href: '#services',     label: 'שירותים' },
  { href: '#testimonials', label: 'המלצות' },
  { href: '#contact',      label: 'יצירת קשר' },
];
---

<header
  id="site-header"
  class="fixed inset-x-0 top-0 z-50 transition-all duration-500 ease-out"
  aria-label="כותרת אתר"
>
  <div class="container-prose flex items-center py-2 md:py-3 lg:justify-between">

    <!-- Mobile: hamburger (right=start in RTL); hidden on desktop -->
    <button
      id="nav-toggle"
      type="button"
      class="flex h-10 w-10 shrink-0 items-center justify-center text-neutral-700 transition-colors hover:text-teal-600 lg:hidden"
      aria-expanded="false"
      aria-controls="mobile-menu"
      aria-label="פתח תפריט ניווט"
    >
      <svg class="h-6 w-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <line class="menu-bar" id="bar-top" x1="4" y1="7" x2="20" y2="7" stroke-linecap="round" />
        <line class="menu-bar" id="bar-mid" x1="4" y1="12" x2="20" y2="12" stroke-linecap="round" />
        <line class="menu-bar" id="bar-bot" x1="4" y1="17" x2="20" y2="17" stroke-linecap="round" />
      </svg>
    </button>

    <!-- Logo — centered on mobile (flex-1 + justify-center), natural start on desktop -->
    <div class="flex flex-1 items-center justify-center lg:flex-none lg:justify-start">
      <a
        href="/"
        aria-label={`${SITE.name} — עמוד הבית`}
        class="shrink-0 transition-opacity hover:opacity-85"
      >
        <img
          src="/logo.svg"
          alt="גל עופרי פיזיותרפיה — לוגו"
          class="h-14 w-auto md:h-16"
          width="115"
          height="96"
        />
      </a>
    </div>

    <!-- Calendar shortcut — mirrors hamburger size, keeps logo centred on mobile -->
    <a
      id="nav-cal-btn"
      href="#contact"
      class="flex h-10 w-10 shrink-0 items-center justify-center rounded-xl border border-teal-200 text-teal-600 transition-colors hover:border-teal-300 hover:bg-teal-50 active:bg-teal-100 lg:hidden"
      aria-label="לקביעת תור"
    >
      <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-linejoin="round"/>
        <path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/>
      </svg>
    </a>

    <!-- Desktop Nav Links; hidden on mobile -->
    <nav aria-label="ניווט ראשי" class="hidden items-center gap-2 lg:flex">
      {links.map(({ href, label }) => (
        <a
          href={href}
          class="rounded-lg px-5 py-2 text-sm font-medium text-neutral-700 transition-colors duration-200 hover:text-teal-600 focus-visible:text-teal-600"
        >
          {label}
        </a>
      ))}
    </nav>

    <!-- Desktop Actions; hidden on mobile -->
    <div class="hidden items-center gap-4 lg:flex">
      <a
        href={`tel:${SITE.phoneE164}`}
        aria-label={`חייג ל-${SITE.name}: ${SITE.phone}`}
        class="flex items-center gap-1.5 text-sm font-medium text-neutral-500 transition-colors hover:text-neutral-800"
      >
        <svg class="h-4 w-4 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.33a2 2 0 0 1 2-1.72h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.94 6.94l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
        <span dir="ltr" class="tracking-wide">{SITE.phone}</span>
      </a>
      <a
        href={SITE.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex h-9 w-9 items-center justify-center rounded-full text-neutral-400 transition-colors hover:text-whatsapp"
        aria-label="שלחו הודעה לגל עופרי בוואטסאפ"
      >
        <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
        </svg>
      </a>
      <a
        href="#contact"
        class="btn-primary py-2.5 text-sm"
        aria-label="לחצו לתיאום ייעוץ ראשוני עם גל עופרי פיזיותרפיה"
      >
        לתיאום ייעוץ ראשוני
      </a>
    </div>

  </div>
</header>

<!-- ── Mobile Menu Overlay ── -->
<div
  id="mobile-menu"
  role="dialog"
  aria-modal="true"
  aria-label="תפריט ניווט"
>
  <!-- Top bar: close (right in RTL), logo (center), spacer (left) -->
  <div class="container-prose grid grid-cols-[2.5rem_1fr_2.5rem] items-center gap-3 py-4">
    <button
      id="nav-close-btn"
      type="button"
      class="flex h-10 w-10 items-center justify-center rounded-xl text-neutral-500 transition-colors hover:bg-neutral-100 hover:text-neutral-800"
      aria-label="סגור תפריט ניווט"
    >
      <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" d="M18 6 6 18M6 6l12 12"/>
      </svg>
    </button>
    <a href="/" aria-label={`${SITE.name} — עמוד הבית`} class="flex justify-center">
      <img src="/logo.svg" alt="גל עופרי פיזיותרפיה — לוגו" class="h-12 w-auto" width="86" height="64" />
    </a>
    <div aria-hidden="true"></div>
  </div>

  <!-- Nav links (centered, full height) -->
  <nav
    aria-label="תפריט ניווט נייד"
    class="flex flex-1 flex-col items-center justify-center gap-2 px-6"
  >
    {links.map(({ href, label }) => (
      <a
        href={href}
        class="w-full rounded-2xl py-4 text-center text-xl font-semibold text-neutral-700 transition-all duration-150 hover:bg-neutral-100 hover:text-teal-700 active:scale-[0.97]"
      >
        {label}
      </a>
    ))}
  </nav>

  <!-- Bottom CTA area -->
  <div class="container-prose flex flex-col gap-3 pb-10 pt-4">
    <a
      href="#contact"
      class="btn-primary justify-center py-4 text-base"
      aria-label="תיאום ייעוץ ראשוני ופגישה ראשונה עם גל עופרי"
    >
      <svg class="h-5 w-5 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke-linejoin="round"/>
        <path stroke-linecap="round" d="M16 2v4M8 2v4M3 10h18"/>
      </svg>
      תיאום ייעוץ ראשוני
    </a>
    <a
      href={`tel:${SITE.phoneE164}`}
      class="flex items-center justify-center gap-2 text-sm text-neutral-500 transition-colors hover:text-neutral-700"
      aria-label={`חייג: ${SITE.phone}`}
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.62 3.33a2 2 0 0 1 2-1.72h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9a16 16 0 0 0 6.94 6.94l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      <span dir="ltr">{SITE.phone}</span>
    </a>
  </div>
</div>

<style>
  /* ── Header scroll state ── */
  #site-header {
    background: var(--color-neutral-50);
  }
  #site-header.is-scrolled {
    background: color-mix(in srgb, var(--color-neutral-50) 82%, transparent);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    box-shadow: 0 1px 32px -8px rgb(0 0 0 / 0.08);
  }
  #site-header.menu-open {
    box-shadow: 0 4px 24px -4px rgb(0 0 0 / 0.12);
  }

  /* ── Hamburger → X animation ── */
  .menu-bar {
    transform-box: stroke-box;
    transform-origin: center;
    transition: transform 300ms cubic-bezier(0.16, 1, 0.3, 1), opacity 200ms ease;
  }
  #nav-toggle[aria-expanded='true'] #bar-top {
    transform: translateY(5px) rotate(45deg);
  }
  #nav-toggle[aria-expanded='true'] #bar-mid {
    opacity: 0;
  }
  #nav-toggle[aria-expanded='true'] #bar-bot {
    transform: translateY(-5px) rotate(-45deg);
  }

  /* ── Mobile menu overlay — animated entrance/exit ── */
  #mobile-menu {
    display: flex;
    flex-direction: column;
    position: fixed;
    inset: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--color-neutral-50) 98%, transparent);
    backdrop-filter: blur(24px) saturate(160%);
    -webkit-backdrop-filter: blur(24px) saturate(160%);

    visibility: hidden;
    opacity: 0;
    transform: translateY(-10px) scale(0.985);
    transition:
      opacity 300ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 300ms cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0ms linear 300ms;
  }
  #mobile-menu[data-open='true'] {
    visibility: visible;
    opacity: 1;
    transform: translateY(0) scale(1);
    transition:
      opacity 300ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 300ms cubic-bezier(0.16, 1, 0.3, 1),
      visibility 0ms linear 0ms;
  }
</style>

<script>
  const header   = document.getElementById('site-header')!;
  const toggle   = document.getElementById('nav-toggle')!;
  const closeBtn = document.getElementById('nav-close-btn')!;
  const menu     = document.getElementById('mobile-menu')!;
  const mainEl   = document.getElementById('main-content')!;
  const footerEl = document.querySelector('footer')!;

  // ── Scroll → frosted glass ──
  const syncHeader = () => header.classList.toggle('is-scrolled', window.scrollY > 20);
  window.addEventListener('scroll', syncHeader, { passive: true });
  syncHeader();

  // ── Menu helpers ──
  const openMenu = () => {
    menu.dataset.open = 'true';
    toggle.setAttribute('aria-expanded', 'true');
    toggle.setAttribute('aria-label', 'סגור תפריט ניווט');
    document.body.style.overflow = 'hidden';
    header.classList.add('menu-open');
    mainEl.setAttribute('inert', '');
    footerEl.setAttribute('inert', '');
    (menu.querySelector('a') as HTMLElement | null)?.focus();
  };

  const closeMenu = () => {
    menu.dataset.open = 'false';
    toggle.setAttribute('aria-expanded', 'false');
    toggle.setAttribute('aria-label', 'פתח תפריט ניווט');
    document.body.style.overflow = '';
    header.classList.remove('menu-open');
    mainEl.removeAttribute('inert');
    footerEl.removeAttribute('inert');
    toggle.focus();
  };

  toggle.addEventListener('click', () => (menu.dataset.open === 'true' ? closeMenu() : openMenu()));
  closeBtn.addEventListener('click', closeMenu);
  menu.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));
  document.getElementById('nav-cal-btn')?.addEventListener('click', closeMenu);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeMenu(); });
</script>

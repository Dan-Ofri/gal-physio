---
import { Image } from 'astro:assets';
import galAbout from '../assets/gal-about.jpg';

const credentials = [
  'פיזיותרפיסטית מוסמכת (B.P.T)',
  'בוגרת החוג לפיזיותרפיה',
  'למעלה מ-10 שנות ניסיון קליני',
  'לשעבר ספורטאית התעמלות תחרותית',
];
---

<section
  id="about"
  aria-labelledby="about-heading"
  class="section-padding bg-neutral-50"
>
  <div class="container-prose">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">

      <!--
        Photo: right column in RTL (lg:order-1 = first grid position = right in RTL),
        bottom on mobile (order-2).
      -->
      <div class="order-2 lg:order-1">
        <div class="relative">
          <!-- Decorative soft halo behind the frame -->
          <div
            aria-hidden="true"
            class="absolute -inset-6 rounded-[2.5rem] bg-gradient-to-br from-teal-100/60 to-teal-50/30 blur-sm"
          ></div>

          <figure class="relative overflow-hidden rounded-[2rem] shadow-card-hover ring-1 ring-teal-200/40">
            <Image
              src={galAbout}
              alt="גל עופרי פיזיותרפיסטית בתל אביב — טיפול פיזיותרפיה ודיקור יבש בקליניקה"
              width={480}
              height={560}
              loading="lazy"
              class="block w-full object-cover object-top"
            />
          </figure>

          <!-- Floating experience badge -->
          <div
            class="absolute -top-5 -end-5 rounded-2xl bg-white px-5 py-3.5 shadow-card ring-1 ring-neutral-200/70"
            role="note"
            aria-label="10 שנות ניסיון קליני ויותר"
          >
            <p class="font-serif text-3xl font-bold leading-none text-teal-800">10+</p>
            <p class="mt-0.5 text-xs font-medium text-neutral-500">שנות ניסיון</p>
          </div>
        </div>
      </div>

      <!--
        Text: left column in RTL (lg:order-2 = second grid position = left in RTL),
        top on mobile (order-1).
      -->
      <div class="order-1 lg:order-2">

        <!-- Eyebrow -->
        <p class="text-xs font-semibold uppercase tracking-widest text-teal-700" aria-hidden="true">
          אודות
        </p>

        <!-- H2 — "פיזיותרפיסטית מוסמכת" is the primary keyword here -->
        <h2
          id="about-heading"
          class="mt-3 font-serif text-3xl font-bold leading-tight text-neutral-900 md:text-4xl"
        >
          נעים להכיר, אני גל
          <span class="sr-only">— פיזיותרפיסטית מוסמכת לשיקום ופיזיותרפיה</span>
        </h2>

        <!-- Introduction -->
        <p class="mt-5 leading-relaxed text-neutral-600">
          אני גל עופרי,
          <strong class="font-semibold text-neutral-800">פיזיותרפיסטית מוסמכת</strong>
          עם למעלה מעשור של ניסיון בטיפול ושיקום. בוגרת החוג לפיזיותרפיה, אני משלבת ידע מדעי עמוק עם גישה אישית וחמה — כי מאחורי כל פציעה יש אדם עם חיים, חלומות ומטרות.
        </p>

        <!-- Pull Quote — gymnast experience builds empathy and trust -->
        <blockquote
          class="my-7 rounded-e-2xl border-s-[3px] border-s-teal-600 bg-teal-50/80 py-5 pe-5 ps-6"
          aria-label="ציטוט אישי של גל עופרי"
        >
          <svg
            aria-hidden="true"
            class="mb-3 h-7 w-7 text-teal-300"
            viewBox="0 0 24 24"
            fill="currentColor"
          >
            <!-- Decorative opening quote mark -->
            <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
          </svg>
          <p class="font-serif text-[1.0625rem] italic leading-relaxed text-neutral-700">
            כשהייתי ספורטאית תחרותית, חוויתי בגופי את הפחד מהפציעה ואת הדרך הארוכה חזרה לאימונים.
            אותה חוויה אישית היא שמאפשרת לי להבין באמת מה המטופלים שלי עוברים — ולהיות שם
            בשבילם בצורה שיוצרת שינוי אמיתי.
          </p>
          <footer class="mt-3">
            <cite class="text-sm font-semibold not-italic text-teal-700">— גל עופרי</cite>
          </footer>
        </blockquote>

        <!-- Philosophy -->
        <p class="leading-relaxed text-neutral-600">
          אני מאמינה ש<strong class="font-semibold text-neutral-800">הגוף יודע לרפא את עצמו</strong>
          — הוא פשוט זקוק לכלים הנכונים, לידיים המומחות ולמרחב הנכון לעשות זאת. בקליניקה שלי,
          כל תוכנית טיפול מותאמת לך: לקצב שלך, לגוף שלך ולמטרות שלך.
        </p>

        <!-- Credentials list -->
        <ul
          class="mt-7 space-y-2.5"
          aria-label="כישורים ורקע מקצועי של גל עופרי"
        >
          {credentials.map((item) => (
            <li class="flex items-center gap-3">
              <span
                aria-hidden="true"
                class="flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-teal-100"
              >
                <svg
                  class="h-3.5 w-3.5 text-teal-700"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  aria-hidden="true"
                >
                  <polyline
                    points="20 6 9 17 4 12"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                  />
                </svg>
              </span>
              <span class="text-sm font-medium text-neutral-700">{item}</span>
            </li>
          ))}
        </ul>

        <!-- CTA -->
        <div class="mt-8">
          <a
            href="#contact"
            class="btn-primary"
            aria-label="לתיאום ייעוץ ראשוני ופגישה ראשונה עם גל עופרי, פיזיותרפיסטית מוסמכת"
          >
            <svg
              class="h-5 w-5 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="7" r="4" stroke-linejoin="round"/>
            </svg>
            בואו נכיר — תיאום ייעוץ ראשוני
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

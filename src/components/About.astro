---
import { Image } from 'astro:assets';
import galAboutPro from '../assets/gal-about-pro.jpeg';

---

<section
  id="about"
  aria-labelledby="about-heading"
  class="section-padding bg-neutral-50"
>
  <div class="container-prose">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">

      <!--
        Photo: right column in RTL (lg:order-1 = first grid position = right in RTL),
        bottom on mobile (order-2).
      -->
      <div class="order-2 lg:order-1">
        <div class="relative">
          <!-- Decorative soft halo -->
          <div
            aria-hidden="true"
            class="absolute -inset-4 rounded-[2.5rem] bg-gradient-to-br from-teal-50/80 to-transparent blur-sm"
          ></div>

          <figure class="relative overflow-hidden rounded-[2rem] shadow-card ring-1 ring-neutral-200/60">
            <Image
              src={galAboutPro}
              alt="גל עופרי פיזיותרפיסטית מוסמכת מבצעת טיפול — קליניקה בתל אביב"
              width={480}
              height={560}
              loading="lazy"
              class="block w-full object-cover object-top"
            />
          </figure>
        </div>
      </div>

      <!--
        Text: left column in RTL (lg:order-2 = second grid position = left in RTL),
        top on mobile (order-1).
      -->
      <div class="order-1 lg:order-2">

        <!-- Eyebrow -->
        <p class="text-xs font-semibold uppercase tracking-widest text-accent-gold" aria-hidden="true">
          אודות
        </p>

        <!-- H2 — "פיזיותרפיסטית מוסמכת" is the primary keyword here -->
        <h2
          id="about-heading"
          class="mt-3 font-serif text-3xl font-bold leading-tight text-teal-700 md:text-4xl"
        >
          נעים להכיר, אני גל
          <span class="sr-only">— פיזיותרפיסטית מוסמכת לשיקום ופיזיותרפיה</span>
        </h2>
        <p class="mt-2 text-sm font-medium tracking-wide text-teal-700">
          B.P.T · פיזיותרפיסטית מוסמכת · לשעבר ספורטאית תחרותית
        </p>

        <!-- Introduction -->
        <p class="mt-5 leading-relaxed text-neutral-600">
          אני גל עופרי,
          <strong class="font-semibold text-neutral-800">פיזיותרפיסטית מוסמכת</strong>
          בוגרת החוג לפיזיותרפיה. אני משלבת ידע מדעי עמוק עם גישה אישית וחמה — כי מאחורי כל פציעה יש אדם עם חיים, חלומות ומטרות.
        </p>

        <!-- Philosophy -->
        <p class="leading-relaxed text-neutral-600">
          אני מאמינה ש<strong class="font-semibold text-neutral-800">הגוף יודע לרפא את עצמו</strong>
          — הוא פשוט זקוק לכלים הנכונים, לידיים המומחות ולמרחב הנכון לעשות זאת. בקליניקה שלי,
          כל תוכנית טיפול מותאמת לך: לקצב שלך, לגוף שלך ולמטרות שלך.
        </p>

        <!-- Credentials — SEO-readable, visually silent -->
        <ul class="sr-only" aria-label="כישורים ורקע מקצועי של גל עופרי">
          <li>פיזיותרפיסטית מוסמכת B.P.T</li>
          <li>בוגרת החוג לפיזיותרפיה</li>
          <li>לשעבר ספורטאית התעמלות תחרותית</li>
        </ul>

        <!-- CTA -->
        <div class="mt-8">
          <a
            href="#contact"
            class="btn-primary"
            aria-label="לתיאום ייעוץ ראשוני ופגישה ראשונה עם גל עופרי, פיזיותרפיסטית מוסמכת"
          >
            <svg
              class="h-5 w-5 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="7" r="4" stroke-linejoin="round"/>
            </svg>
            לתיאום ייעוץ ראשוני
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

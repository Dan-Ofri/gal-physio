---
import { Image } from 'astro:assets';
import galAboutPro from '../assets/about-ref.jpeg';

---

<section
  id="about"
  aria-labelledby="about-heading"
  class="section-padding bg-neutral-50"
>
  <div class="container-prose">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">

      <!--
        Photo: right column in RTL (lg:order-1 = first grid position = right in RTL),
        bottom on mobile (order-2).
      -->
      <div class="order-2 lg:order-1">
        <div class="relative">
          <!-- Decorative soft halo -->
          <div
            aria-hidden="true"
            class="absolute -inset-4 rounded-[2.5rem] bg-gradient-to-br from-teal-50/80 to-transparent blur-sm"
          ></div>

          <figure class="relative overflow-hidden rounded-3xl shadow-card ring-1 ring-neutral-200/60">
            <Image
              src={galAboutPro}
              alt="גל עופרי פיזיותרפיסטית מוסמכת מלווה מטופל צעיר בשיקום רגל — תמונת ייחוס"
              width={480}
              height={560}
              loading="lazy"
              class="block w-full object-cover object-top"
            />
          </figure>
        </div>
      </div>

      <!--
        Text: left column in RTL (lg:order-2 = second grid position = left in RTL),
        top on mobile (order-1).
      -->
      <div class="order-1 px-6 text-start lg:order-2 lg:px-0">

        <!-- Eyebrow -->
        <p class="text-xs font-semibold tracking-wide text-teal-600" aria-hidden="true">
          אודות
        </p>

        <!-- H2 -->
        <h2
          id="about-heading"
          class="mt-3 font-serif text-3xl font-bold leading-tight text-teal-700 md:text-4xl"
        >
          גל עופרי
          <span class="sr-only">— פיזיותרפיסטית מוסמכת לשיקום ופיזיותרפיה</span>
        </h2>
        <p class="mt-2 text-sm font-medium tracking-wide text-teal-700">
          פיזיותרפיסטית מוסמכת (B.P.T) | מתעמלת תחרותית לשעבר
        </p>

        <!-- Introduction -->
        <p class="mt-5 leading-[1.85] text-neutral-600">
          נעים מאוד, אני גל עופרי –
          <strong class="font-semibold text-neutral-800">עם תשוקה אמיתית לעזור לאנשים</strong>
          לחזור לנוע בחופשיות ולהרגיש טוב בגוף שלהם. הגעתי לתחום מתוך אהבה עמוקה לתנועה ולאנשים.
        </p>

        <!-- Personal story -->
        <p class="mt-5 leading-[1.85] text-neutral-600">
          כ<strong class="font-semibold text-neutral-800">מתעמלת תחרותית לשעבר</strong>
          שחוותה פציעות ותהליכי שיקום מורכבים בעצמה, אני מכירה מקרוב לא רק את האנטומיה, אלא גם את האתגר המנטלי הכרוך בכאב. בשנים האחרונות אני מלווה ספורטאים, מתבגרים ומבוגרים בתהליכי שיקום ושיפור ביצועים.
        </p>

        <!-- Philosophy -->
        <p class="mt-5 leading-[1.85] text-neutral-600">
          מה שמניע אותי הוא הרגע שבו המטופלים מבינים שהם יכולים לחזור לרוץ, להתאמן, להרים את הילד בלי כאב, או פשוט לקום בבוקר ולהרגיש קל יותר בגוף. אני מאמינה שטיפול הוא הסתכלות על
          <strong class="font-semibold text-neutral-800">האדם כולו</strong>:
          על ההרגלים, הנפש, והיכולת של הגוף לרפא את עצמו כשנותנים לו את הכלים והליווי הנכונים.
        </p>

        <!-- Credentials — SEO-readable, visually silent -->
        <ul class="sr-only" aria-label="כישורים ורקע מקצועי של גל עופרי">
          <li>פיזיותרפיסטית מוסמכת B.P.T</li>
          <li>בוגרת החוג לפיזיותרפיה</li>
          <li>לשעבר מתעמלת תחרותית</li>
        </ul>

        <!-- CTA -->
        <div class="mt-8 flex justify-start">
          <a
            href="#contact"
            class="btn-primary"
            aria-label="לתיאום ייעוץ ראשוני ופגישה ראשונה עם גל עופרי, פיזיותרפיסטית מוסמכת"
          >
            <svg
              class="h-5 w-5 shrink-0"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="7" r="4" stroke-linejoin="round"/>
            </svg>
            לתיאום ייעוץ ראשוני
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
